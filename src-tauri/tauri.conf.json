{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OPIDE",
  "version": "0.1.0",
  "identifier": "com.openpawz.opide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "freezePrototype": false,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 OpenPawz. All rights reserved.",
    "shortDescription": "AI-native IDE",
    "longDescription": "OPIDE is an AI-native desktop IDE built on Rust and Tauri with the VS Code workbench, a multi-agent coding engine, and codebase-aware memory.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../node-extension-host/dist/*": "node-extension-host/dist/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://releases.openpawz.com/opide/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "PLACEHOLDER_GENERATE_WITH_TAURI_SIGNER"
    }
  }
}
